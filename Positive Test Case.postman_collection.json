			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"success\", function () { // apakah requestnya berhasil atau tidak",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"this is array\", function () { //apakah bentuk dari responsenya itu array?",
							"    const json = pm.response.json();",
							"    pm.expect(json).to.be.an(\"array\"); // ini bisa diganti object, string, atau yang lain",
							"});",
							"",
							"pm.test(\"Array is not empty\", function () { // jika array, apakah di arraynya kosong atau ada isinya?",
							"    const json = pm.response.json();",
							"    pm.expect(json.length).to.be.above(0);",
							"});",
							"",
							"pm.test(\"Each post has correct structure\", function () { // apakah disetiap post (id) itu lengkap? (id, userId, title, dan body) ?",
							"    const json = pm.response.json();",
							"    json.forEach(post => {",
							"        pm.expect(post).to.have.property(\"id\");",
							"        pm.expect(post).to.have.property(\"userId\");",
							"        pm.expect(post).to.have.property(\"title\");",
							"        pm.expect(post).to.have.property(\"body\");",
							"    });",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
